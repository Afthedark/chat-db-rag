# Google Gemini API Configuration
GEMINI_API_KEY_ID_1 = ""

# =============================================================================
# OLLAMA PERFORMANCE CONFIGURATION
# =============================================================================

# Configuración optimizada para llama3.1:8b (modelo rápido y ligero)
OLLAMA_TIMEOUT=120           # Timeout: 2 minutos (suficiente para llama3.1:8b)
OLLAMA_MAX_RETRIES=3         # Reintentos ante fallos transitorios
OLLAMA_RETRY_DELAY=2         # Delay inicial de 2 segundos entre reintentos
OLLAMA_CONTEXT_LIMIT=4096    # Context window estándar para modelos 8B
MAX_CHAT_HISTORY=3           # Últimos 3 mensajes de historial

# =============================================================================
# CONFIGURACIÓN ALTERNATIVA PARA MODELOS GRANDES
# =============================================================================
# Descomenta estas líneas si usas deepseek-r1:14b, llama3.3:70b, etc.
# OLLAMA_TIMEOUT=600         # 10 minutos para modelos grandes
# OLLAMA_MAX_RETRIES=2       # Menos reintentos para no esperar tanto
# OLLAMA_RETRY_DELAY=5       # Mayor delay inicial
# OLLAMA_CONTEXT_LIMIT=8192  # Mayor contexto para modelos grandes
# MAX_CHAT_HISTORY=2         # Menos historial para reducir tokens
